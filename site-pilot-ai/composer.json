{
  "name": "mumega/mumega-mcp-dev",
  "description": "Development dependencies for Mumega MCP plugin quality checks",
  "type": "project",
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "squizlabs/php_codesniffer": "^3.10"
  },
  "scripts": {
    "test": "phpunit --configuration tests/phpunit.xml",
    "lint:tests": "find tests -name '*.php' -print0 | xargs -0 -n1 php -l"
  }
}
