              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<div style=\"text-align:center;\">\n<p style=\"font-size:12px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#1B4DFF;margin-bottom:16px;\">GET STARTED</p>\n<h1 style=\"font-size:56px;font-weight:800;letter-spacing:-0.02em;line-height:1.1;margin-bottom:24px;color:#0B1220;\">Up and Running in <span style=\"background:linear-gradient(90deg,#0B1220 0%,#1B4DFF 45%,#00B7A8 95%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;\">5 Minutes</span></h1>\n<p style=\"font-size:20px;line-height:1.6;color:#4B5563;max-width:680px;margin:0 auto;\">Install the plugin, grab your API key, configure your AI client, and start controlling WordPress with natural language.</p>\n</div>"
