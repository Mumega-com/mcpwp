              "settings": {
                "html": "<div style=\"display:flex;gap:48px;align-items:flex-start;max-width:860px;margin:0 auto;\">\n<div style=\"flex-shrink:0;\">\n<span style=\"font-size:96px;font-weight:900;line-height:1;background:linear-gradient(90deg,#0B1220 0%,#1B4DFF 45%,#00B7A8 95%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;\">3</span>\n</div>\n<div style=\"flex:1;\">\n<h2 style=\"font-size:36px;font-weight:800;letter-spacing:-0.02em;color:#0B1220;margin-bottom:24px;\">Connect to Claude, Cursor, or Any MCP Client</h2>\n<p style=\"font-size:17px;color:#4B5563;margin-bottom:20px;\">Add this to your MCP client configuration:</p>\n<div style=\"background:#0B1220;border-radius:18px;padding:28px 32px;overflow-x:auto;\">\n<pre style=\"margin:0;font-family:'JetBrains Mono',Consolas,monospace;font-size:14px;line-height:1.7;color:#E5E7EB;\"><code>{\n  \"mcpServers\": {\n    \"site-pilot-ai\": {\n      \"url\": \"https://yoursite.com/wp-json/site-pilot-ai/v1/mcp\",\n      \"headers\": {\n        \"X-API-Key\": \"spai_your_api_key_here\"\n      }\n    }\n  }\n}</code></pre>\n</div>\n<p style=\"font-size:15px;color:#6B7280;margin-top:16px;font-style:italic;\">Replace <strong>yoursite.com</strong> with your domain and the API key with your actual key.</p>\n</div>\n</div>"
